{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "electronVersion": "33.2.0",
  "appId": "com.ccclawai.ccclaw",
  "productName": "Ccclaw",
  "asar": true,
  "forceCodeSigning": false,
  "directories": {
    "output": "release/${env.CCCLAW_DISPLAY_VERSION}"
  },
  "files": [
    "dist-electron",
    "dist"
  ],
  "extraResources": [
    {
      "from": "LICENSE",
      "to": "LICENSE"
    },
    {
      "from": "NOTICE",
      "to": "NOTICE"
    },
    {
      "from": "src/assets/logo.png",
      "to": "app-icon.png"
    }
  ],
  "mac": {
    "icon": "build/icon.icns",
    "category": "public.app-category.developer-tools",
    "artifactName": "Ccclaw-Lite_${env.CCCLAW_DISPLAY_VERSION}.${ext}",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "sign": false,
    "strictVerify": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.inherit.plist",
    "notarize": false,
    "target": [
      "dmg",
      "zip"
    ]
  },
  "dmg": {
    "writeUpdateInfo": true,
    "sign": false,
    "format": "UDZO"
  },
  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64",
          "ia32"
        ]
      },
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "Ccclaw-Lite-Setup_${env.CCCLAW_DISPLAY_VERSION}_${arch}.${ext}",
    "legalTrademarks": "Copyright © 2024 秋芝2046. All rights reserved.",
    "requestedExecutionLevel": "asInvoker",
    "verifyUpdateCodeSignature": false
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": true,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "installerHeaderIcon": "build/icon.ico",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Ccclaw",
    "include": "build/installer.nsh",
    "deleteAppDataOnUninstall": false,
    "runAfterFinish": true,
    "menuCategory": true,
    "installerLanguages": [
      "zh_CN",
      "en_US",
      "zh_TW"
    ],
    "language": "2052",
    "multiLanguageInstaller": true,
    "packElevateHelper": true,
    "guid": "ccclaw-lite-install-guid",
    "warningsAsErrors": false
  },
  "portable": {
    "artifactName": "Ccclaw-Lite-Portable_${env.CCCLAW_DISPLAY_VERSION}.${ext}"
  },
  "publish": {
    "provider": "generic",
    "channel": "latest",
    "url": "https://example.invalid/ccclaw-lite/updates/latest"
  }
}
